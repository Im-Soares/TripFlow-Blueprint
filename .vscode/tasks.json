{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "TripFlow: Install dependencies",
      "type": "shell",
      "command": "pnpm install",
      "problemMatcher": []
    },
    {
      "label": "TripFlow: Start mobile app in browser",
      "type": "shell",
      "command": "pnpm run dev",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "TripFlow: Start Replit web preview",
      "type": "shell",
      "command": "pnpm run dev:web-preview",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "TripFlow: Start API",
      "type": "shell",
      "command": "pnpm run dev:api",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "TripFlow: Typecheck",
      "type": "shell",
      "command": "pnpm run typecheck",
      "problemMatcher": "$tsc"
    }
  ]
}
